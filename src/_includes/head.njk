<head profile="http://dublincore.org/documents/dcq-html/">
  <title>archipelagos{% if layout == "article" or layout == "project" %} | {{ title.short if title.short else title }}{% endif %}</title>
  <link href="http://gmpg.org/xfn/11" rel="profile" />
  <meta name="google-site-verification" content="tD7Jl4oWLxF6dzzD87josx-uV0PMX6nvL1Vc8QXVECM" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta http-equiv="content-type" content="text/html; charset=utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1" />
  {% if abstract %}
  <meta name="description" content="{{ abstract | striptags | truncate(155) }}" />
  {% else %}
  <meta name="description" content="{{ site.description }}" />
  {% endif %}
  <link rel="canonical" href="{{ site.url }}{{ page.url }}" />
  <link rel="sitemap" type="application/xml" href="{{ '/sitemap.xml' | url }}" />
  {% set basePath = page.url | replace("/es/", "/") | replace("/fr/", "/") %}
  <link rel="alternate" hreflang="en" href="{{ site.url }}{{ basePath }}" />
  <link rel="alternate" hreflang="es" href="{{ site.url }}/es{{ basePath }}" />
  <link rel="alternate" hreflang="fr" href="{{ site.url }}/fr{{ basePath }}" />
  <link rel="alternate" hreflang="x-default" href="{{ site.url }}{{ basePath }}" />

  <!-- Dublin Core metadata -->
  <link rel="schema.DC" href="http://dublincore.org/documents/dces/" />
  <link rel="schema.DCTERMS" href="http://dublincore.org/documents/dces/" />
  <meta name="DC.title" content="{% if layout != 'article' %}archipelagos{% else %}{{ title.long | striptags if title.long else title | striptags }}{% endif %}"/>
  <meta name="DC.creator" content="{% for a in author %}{% if loop.last and not loop.first %} and {{ a.name }}{% elif not loop.first %}, {{ a.name }}{% else %}{{ a.name }}{% endif %}{% endfor %}" />
  <meta name="DC.type" content="Text" />
  <meta name="DCTERMS.abstract" content="{{ abstract | striptags if abstract }}" />
  <meta name="DC.date" content="{{ pubDate }}" />
  <meta name="DCTERMS.issued" content="{{ pubDate }}" />
  <meta name="DC.identifier" scheme="DCTERMS.URI" content="{{ doi }}" />
  <meta name="DC.identifier" scheme="DCTERMS.ISSN" content="{{ site.issn }}" />
  <meta name="DC.publisher" content="{{ site.publisher }}" />
  <meta name="DC.relation.ispartof" content="{{ site.title }}" />
  <meta name="DC.citation.issue" content="{{ issue }}" />
  <meta name="DC.format" content="text/html" />
  <meta name="DCTERMS.license" content="https://creativecommons.org/licenses/by/4.0/" />
  <meta name="DC.source" content="{{ site.title }}" />
  <meta name="DC.language" content="{{ language }}" />

  <!-- Social media metadata -->
  {% if layout == "article" or layout == "project" %}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="{{ title.long | striptags if title.long else title | striptags }}" />
  <meta name="twitter:description" content="{{ abstract | striptags | truncate(200) }}" />
  {% else %}
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content="archipelagos | a journal of Caribbean digital praxis" />
  <meta name="twitter:description" content="{{ site.description }}" />
  {% endif %}
  <meta name="twitter:site" content="@elotroalex" />
  <meta name="twitter:image" content="{{ site.url }}/public/open-graph-logo.png" />

  {% if layout != "article" %}
  <meta property="og:title" content="archipelagos" />
  <meta property="og:description" content="A journal of Caribbean digital praxis" />
  <meta property="fb:admins" content="elotroalex" />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="{{ site.url }}{{ page.url }}" />
  <meta property="fb:app_id" content="837201816410405" />
  <meta property="og:image" content="{{ site.url }}/public/open-graph-logo.png" />
  <meta property="og:image:width" content="200" />
  <meta property="og:image:height" content="200" />
  {% else %}
  <meta property="og:title" content="{{ title.long | striptags if title.long else title | striptags }}"/>
  <meta property="og:description" content="{{ abstract | striptags if abstract }}">
  <meta property="fb:admins" content="elotroalex" />
  <meta property="og:type" content="article" />
  <meta property="og:url" content="{{ site.url }}{{ page.url }}" />
  <meta property="fb:app_id" content="837201816410405" />
  <meta property="og:image" content="{{ site.url }}/public/open-graph-logo.png" />
  <meta property="og:image:width" content="200" />
  <meta property="og:image:height" content="200" />
  {% endif %}

  <!-- Highwire Press metadata (Google Scholar indexing) -->
  {% if layout == "article" %}
  <meta name="citation_journal_title" content="{{ site.title }}" />
  <meta name="citation_issn" content="{{ site.issn }}" />
  <meta name="citation_issue" content="{{ issue }}" />
  <meta name="citation_title" content="{{ title.long | striptags if title.long else title | striptags }}"/>
  {% for a in author %}
  <meta name="citation_author" content="{{ a.name }}" />
  {% endfor %}
  <meta name="citation_publication_date" content="{{ pubDate | isoDate }}" />
  <meta name="citation_language" content="{{ language }}" />
  <meta name="citation_fulltext_html_url" content="{{ site.url }}{{ page.url }}" />
  {% if pdf != false %}
  {% set canonicalPath = page.url | replace("/es/", "/") | replace("/fr/", "/") %}
  <meta name="citation_pdf_url" content="{{ site.url }}/assets{{ canonicalPath | replace('.html', '.pdf') }}" />
  {% endif %}
  <meta name="citation_publisher" content="{{ site.publisher }}" />
  <meta name="citation_doi" content="{{ doi }}" />
  {% endif %}

  <!-- CSS -->
  <link rel="stylesheet" href="{{ '/public/css/syntax.css' | url }}" />
  <link rel="stylesheet" href="{{ '/public/css/main.css' | url }}" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=PT+Serif:400,400italic,700%7CPT+Sans:400" />

  <!-- Icons -->
  <link rel="apple-touch-icon" sizes="144x144" href="{{ site.url }}/public/apple-touch-icon.png" />
  <link rel="shortcut icon" href="{{ '/public/favicon.ico' | url }}" />

  <!-- RSS (atom.xml not yet generated — re-enable when feed is available) -->
  <!-- <link rel="alternate" type="application/rss+xml" title="RSS" href="{{ '/atom.xml' | url }}" /> -->
</head>
